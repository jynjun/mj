{
  "extends": "@mj/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node", "electron"],
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
