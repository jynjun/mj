{
  "name": "mj-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MJ App - assistant Maitre du Jeu Loup-Garou (monorepo Turborepo + pnpm)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:desktop": "cross-env BUILD_TARGET=desktop turbo run build --filter @mj/web",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "sync-version": "node scripts/sync-version.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
